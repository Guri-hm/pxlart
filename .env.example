# ===== frontend/.env.example =====
# このファイルをコピーして .env.local (ローカル開発用) を作成してください。
# .env.local は .gitignore に追加してコミットしないこと。

# Flask バックエンドのベース URL (ポートを含む)
# ローカル開発: https://localhost:800
# 本番 (GitHub Pages からのアクセス): https://solopg.com
NEXT_PUBLIC_API_BASE=https://localhost:800

# GitHub Pages のパスプレフィックス
# プロジェクトページ (https://<user>.github.io/<repo>/) の場合は /<リポジトリ名>
# ユーザー/組織ページ または カスタムドメインの場合は空文字
BASE_PATH=
